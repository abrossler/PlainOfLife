{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    /* Use bundler module resolution — allows extensionless TS imports (tsx handles
       actual resolution at runtime, so we don't need strict nodenext here) */
    "module": "preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true

    /* noUnusedLocals/Parameters omitted intentionally: src/pol/ domain files are shared
       with the app tsconfig and have pre-existing unused params in abstract base classes */
  },
  "include": ["src/server/**/*.ts", "src/pol/**/*.ts"],
  "exclude": ["src/pol/**/*.spec.ts", "src/test_stubs/**/*.ts"]
}
